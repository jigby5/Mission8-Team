@model Mission8_Team.Models.TaskInstance

<div class="container">
    <h2 class="mb-3">Delete Task</h2>

    <div class="alert alert-warning">
        Are you sure you want to delete this task?
    </div>

    <div class="mb-3">
        <div><strong>@Model.TaskName</strong></div>
        <div class="text-muted">
            Quadrant @Model.Quadrant
            @if (Model.Category != null)
            {
                <span> | @Model.Category.CategoryName</span>
            }
        </div>
    </div>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" name="id" value="@Model.TaskId" />
        <button class="btn btn-danger" type="submit">Delete</button>
        <a class="btn btn-secondary" asp-action="Quadrants">Cancel</a>
    </form>
</div>