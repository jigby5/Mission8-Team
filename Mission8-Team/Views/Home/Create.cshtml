@model Mission8_Team.Models.TaskInstance
@{
}

<div class="row justify-content-center">
    <div class="col-md-8">

        <h2 class="mb-4">Add New Task</h2>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Task Name -->
            <div class="mb-3">
                <label asp-for="TaskName" class="form-label fw-bold">Task <span class="text-danger">*</span></label>
                <input asp-for="TaskName" class="form-control" placeholder="Enter task description" />
                <span asp-validation-for="TaskName" class="text-danger"></span>
            </div>

            <!-- Due Date -->
            <div class="mb-3">
                <label asp-for="DueDate" class="form-label fw-bold">Due Date</label>
                <input asp-for="DueDate" type="date" class="form-control" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <!-- Quadrant -->
            <div class="mb-3">
                <label asp-for="Quadrant" class="form-label fw-bold">Quadrant <span class="text-danger">*</span></label>
                <select asp-for="Quadrant" class="form-select">
                    <option value="">-- Select a Quadrant --</option>
                    <option value="1">Quadrant I – Important / Urgent</option>
                    <option value="2">Quadrant II – Important / Not Urgent</option>
                    <option value="3">Quadrant III – Not Important / Urgent</option>
                    <option value="4">Quadrant IV – Not Important / Not Urgent</option>
                </select>
                <span asp-validation-for="Quadrant" class="text-danger"></span>
            </div>

            <!-- Category Dropdown (from database) -->
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label fw-bold">Category</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                    <option value="">-- Select a Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <!-- Completed -->
            <div class="mb-3 form-check">
                <input asp-for="Completed" class="form-check-input" type="checkbox" />
                <label asp-for="Completed" class="form-check-label">Mark as Completed</label>
            </div>

            <!-- Buttons -->
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Task</button>
                <a asp-action="Quadrants" class="btn btn-secondary">Cancel</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}